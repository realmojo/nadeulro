# 나들로 환경변수 예시 — 실제 값은 .env.local 에 두고 커밋하지 마세요.

# 카카오맵 JavaScript 앱키 (클라이언트 노출 전제, JS 키)
# 카카오 개발자 콘솔 > 앱 > 앱키 > JavaScript 키
# 주의: 배포 도메인을 [플랫폼 > Web]에 사전 등록해야 지도가 동작합니다.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# (선택) 카카오 REST API 키 — 서버측 로컬 API(지오코딩/장소검색)용
KAKAO_REST_API_KEY=

# (선택) 공공데이터포털 서비스키 — 파크골프장/시설 오픈 API용
DATA_GO_KR_SERVICE_KEY=

# (선택) 사이트 배포 URL (메타데이터/사이트맵 기준)
NEXT_PUBLIC_SITE_URL=https://nadeulro.com
